        <item name="android:textColor">@color/primary_light_dark</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="H1">
        <item name="android:textSize">@dimen/dimens_34sp</item>
        <item name="fontFamily">@font/noto_sans_bold</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="H3">
        <item name="android:textSize">@dimen/dimens_22sp</item>
        <item name="fontFamily">@font/noto_sans_bold</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="H3Tablet">
        <item name="android:textSize">@dimen/dimens_26sp</item>
        <item name="android:lineHeight">@dimen/dimens_36sp</item>
        <item name="fontFamily">@font/noto_sans_bold</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="H2">
        <item name="android:textSize">@dimen/dimens_28sp</item>
        <item name="fontFamily">@font/noto_sans_bold</item>
        <item name="android:textColor">@color/primary_light_darkest</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="SubtitlesRegular">
        <item name="android:textSize">@dimen/dimens_14sp</item>
        <item name="fontFamily">@font/noto_sans_medium</item>
        <item name="android:textColor">@color/primary_light_dark</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="SubtitlesMedium">
        <item name="android:textSize">@dimen/dimens_14sp</item>
        <item name="fontFamily">@font/noto_sans_bold</item>
        <item name="android:textColor">@color/primary_light_darkest</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="SubtitlesMediumTablet">
        <item name="android:textSize">@dimen/dimens_20sp</item>
        <item name="fontFamily">@font/noto_sans_bold</item>
        <item name="android:textColor">@color/primary_light_darkest</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="CaptionRegular">
        <item name="android:textSize">@dimen/dimens_12sp</item>
        <item name="fontFamily">@font/noto_sans_medium</item>
        <item name="android:textColor">@color/primary_light_dark</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:lineSpacingExtra">4sp</item>
    </style>

    <style name="CaptionRegularTablet">
        <item name="android:textSize">@dimen/dimens_20sp</item>
        <item name="fontFamily">@font/noto_sans_medium</item>
        <item name="android:textColor">@color/primary_light_dark</item>
