    </style>

    <style name="CustomAlertDialog" parent="Theme.Material3.Light.Dialog.Alert">
        <item name="android:windowBackground">@drawable/border_dialog_password_change</item>
    </style>

    <style name="CustomPopupMenuStyle" parent="Widget.Material3.PopupMenu">
        <item name="popupMenuBackground">@drawable/custom_popup_menu</item>
        <item name="android:padding">@dimen/dimens_0dp</item>
        <item name="android:fontFamily">@font/noto_sans_medium</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">@dimen/dimens_12sp</item>
        <item name="android:includeFontPadding">false</item>
    </style>


    <style name="TelekomCalendarTheme" parent="ThemeOverlay.MaterialComponents.MaterialCalendar">
        <item name="materialCalendarStyle">@style/WhiteCalendarStyle</item>
        <item name="materialCalendarHeaderLayout">@style/App.Material3.MaterialCalendar.HeaderLayout</item>
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/franchiser_telekom_srbija_mtel</item>
        <item name="colorPrimaryVariant">@color/white</item>
        <item name="colorOnPrimary">@color/white</item>
    </style>

    <style name="App.Material3.MaterialCalendar.HeaderLayout" parent="@style/Widget.Material3.MaterialCalendar.HeaderLayout">
        <item name="android:background">@color/franchiser_telekom_srbija_mtel</item>
    </style>

    <style name="WhiteCalendarStyle" parent="Widget.Material3.MaterialCalendar">
        <item name="android:background">@color/white</item>
    </style>

</resources>