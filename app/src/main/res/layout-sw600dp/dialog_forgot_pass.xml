<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/white"
            app:cardCornerRadius="@dimen/dimens_26dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/dimens_16dp"
                android:paddingTop="@dimen/dimens_22dp"
                android:paddingBottom="@dimen/dimens_22dp">

                <TextView
                    android:id="@+id/titleDialogForgotPass"
                    style="@style/H3Tablet"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/title_dialog_forgot_pass" />

                <TextView
                    android:id="@+id/errorDialogForgotPass"
                    style="@style/ParagraphTablet"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimens_34dp"
                    android:text="@string/error_dialog_forgot_pass"
                    android:textColor="@color/figmaColorObjection"
                    android:visibility="visible" />

                <TextView
                    android:id="@+id/subtitleDialogForgotPass"
                    style="@style/ParagraphTablet"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimens_4dp"
                    tools:text="@string/subtitle_dialog_forgot_pass" />

                <Button
                    android:id="@+id/bttDialogForgotPass"
                    style="@style/MyButtonStyleTablet"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dimens_48dp"
                    android:layout_marginTop="@dimen/dimens_34dp"
                    tools:text="@string/confirm" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>