<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        tools:context=".view.fragments.my_profile.RefundRequestFragment">

        <TextView
            android:id="@+id/titleRefundRequest"
            style="@style/H2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dimens_100dp"
            android:layout_marginTop="@dimen/dimens_34dp"
            android:text="@string/refund_request"
            android:textColor="@color/primary_light_darkest"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/lineRefundRequest"
            android:layout_width="0dp"
            android:layout_height="@dimen/dimens_2dp"
            android:layout_marginTop="@dimen/dimens_22dp"
            android:layout_marginEnd="@dimen/dimens_100dp"
            android:background="@color/primary_light_light"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/titleRefundRequest"
            app:layout_constraintTop_toBottomOf="@id/titleRefundRequest" />

        <TextView
            android:id="@+id/txExplanationRefundRequest"
            style="@style/Paragraph"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimens_22dp"
            android:text="@string/refund_request_explanation"
            app:layout_constraintEnd_toEndOf="@id/lineRefundRequest"
            app:layout_constraintStart_toStartOf="@id/lineRefundRequest"
            app:layout_constraintTop_toBottomOf="@id/lineRefundRequest" />

        <View
            android:id="@+id/lineSecondRefundRequest"
            android:layout_width="0dp"
            android:layout_height="@dimen/dimens_2dp"
            android:layout_marginTop="@dimen/dimens_22dp"
            android:background="@color/primary_light_light"
            app:layout_constraintEnd_toEndOf="@id/txExplanationRefundRequest"
            app:layout_constraintStart_toStartOf="@id/txExplanationRefundRequest"
            app:layout_constraintTop_toBottomOf="@id/txExplanationRefundRequest" />

        <TextView
            android:id="@+id/txAllRequest"
            style="@style/H3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimens_22dp"
            android:text="@string/all_requests"
            android:textColor="@color/primary_light_darkest"
            app:layout_constraintStart_toStartOf="@id/lineSecondRefundRequest"
            app:layout_constraintTop_toBottomOf="@id/lineSecondRefundRequest" />

        <TextView
            android:id="@+id/txNoRequirements"
            style="@style/Paragraph"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimens_16dp"
            android:text="@string/you_have_no_refund_requests"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="@id/txAllRequest"
            app:layout_constraintTop_toBottomOf="@id/txAllRequest" />

        <ProgressBar
            android:id="@+id/refundLoadingView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimens_30dp"
            android:layout_marginEnd="@dimen/dimens_100dp"
            android:visibility="visible"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/txAllRequest"
            app:layout_constraintTop_toBottomOf="@id/txAllRequest" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvRefundRequest"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/dimens_22dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintBottom_toTopOf="@id/viewLineRf"
            app:layout_constraintEnd_toEndOf="@id/refundLoadingView"
            app:layout_constraintStart_toStartOf="@id/txAllRequest"
            app:layout_constraintTop_toBottomOf="@id/txAllRequest"
            tools:listitem="@layout/item_refund_request_created" />

        <View
            android:id="@+id/viewLineRf"
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:layout_marginBottom="@dimen/dimens_16dp"
            android:background="@color/primary_light_light"
            app:layout_constraintBottom_toTopOf="@id/buttonRequest"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <Button
            android:id="@+id/buttonRequest"
            style="@style/MyButtonStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/dimens_100dp"
            android:layout_marginBottom="@dimen/dimens_16dp"
            android:text="@string/button_request"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            tools:visibility="visible" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>