<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/primary_light_light" />
            <corners
                android:topLeftRadius="@dimen/dimens_20dp"
                android:topRightRadius="@dimen/dimens_20dp" />
        </shape>
    </item>
    <item
        android:left="@dimen/dimens_2dp"
        android:right="@dimen/dimens_2dp"
        android:top="@dimen/dimens_2dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/white" />
            <corners
                android:topLeftRadius="18dp"
                android:topRightRadius="18dp" />
        </shape>
    </item>
</layer-list>