<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/figmaIntroDarkColor"
        tools:context=".view.fragments.intro.IntroScreenAbout">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guidelineFirstIntro2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.60" />

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="@dimen/dimens_0dp"
            android:importantForAccessibility="no"
            android:scaleType="fitXY"
            android:src="@drawable/intro_screen_first"
            app:layout_constraintBottom_toTopOf="@+id/guidelineFirstIntro2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/iv_icon"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/dimens_0dp"
            android:layout_marginStart="@dimen/dimens_16dp"
            android:importantForAccessibility="no"
            android:src="@drawable/t4all"
            app:layout_constraintBottom_toBottomOf="@id/btn_skip_page"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/btn_skip_page" />

        <Button
            android:id="@+id/btn_skip_page"
            style="@style/MyOutlinedButtonSkip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimens_22dp"
            android:layout_marginEnd="@dimen/dimens_16dp"
            android:paddingHorizontal="@dimen/dimens_22dp"
            android:paddingVertical="@dimen/dimens_9dp"
            android:text="@string/skip"
            android:textColor="@color/white"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/textViewWelcome"
            style="@style/H1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/dimens_16dp"
            android:layout_marginBottom="@dimen/dimens_45dp"
            android:text="@string/welcome_to_toll_for_all"
            app:layout_constraintBottom_toBottomOf="@+id/guidelineFirstIntro2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <View
            android:id="@+id/midEclipse"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dimens_3dp"
            android:layout_marginHorizontal="@dimen/dimens_16dp"
            android:layout_marginTop="@dimen/dimens_22dp"
            android:background="@drawable/linear_gradient"
            android:visibility="visible"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textViewWelcome" />

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/dimens_22dp"
            android:paddingHorizontal="@dimen/dimens_16dp"
            app:layout_constraintBottom_toTopOf="@id/progressBar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/midEclipse">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:id="@+id/textViewTitle"
                    style="@style/H3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/what_is_toll_for_all_system"
                    android:textColor="@color/primary_dark_lightest"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    style="@style/Paragraph"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_marginTop="@dimen/dimens_16dp"
                    android:text="@string/toll_for_all_description"
                    android:textColor="@color/primary_dark_lightest"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/textViewTitle" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.core.widget.NestedScrollView>

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dimens_10dp"
            android:layout_marginBottom="@dimen/dimens_16dp"
            android:background="@color/figmaIntroDarkColor"
            android:max="100"
            android:progress="0"
            android:progressBackgroundTint="@color/figmaIntroScreensGreyColor"
            android:progressTint="@color/figmaSplashScreenColor"
            android:progressTintMode="src_over"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
