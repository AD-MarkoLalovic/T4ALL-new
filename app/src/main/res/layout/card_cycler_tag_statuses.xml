<?xml version="1.0" encoding="utf-8"?>
<layout>

    <androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/border_tags_status"
        tools:backgroundTint="@color/tag_active"
        android:layout_marginTop="@dimen/dimens_6dp"
        android:layout_marginEnd="@dimen/dimens_10dp"
        android:paddingHorizontal="@dimen/dimens_8dp">

        <ImageView
            android:id="@+id/flagIcon"
            android:layout_width="@dimen/dimens_22dp"
            android:layout_height="@dimen/dimens_16dp"
            android:layout_marginVertical="@dimen/dimens_10dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:importantForAccessibility="no"
            tools:background="@drawable/flag_serbia" />

        <TextView
            android:id="@+id/countryStatus"
            style="@style/CaptionRegular"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dimens_8dp"
            app:layout_constraintBottom_toBottomOf="@id/flagIcon"
            app:layout_constraintStart_toEndOf="@id/flagIcon"
            app:layout_constraintTop_toTopOf="@id/flagIcon"
            android:fontFamily="@font/noto_sans_regular"
            android:maxLines="5"
            android:ellipsize="end"
            android:scrollHorizontally="true"
            tools:text="Serbia Formedg" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>