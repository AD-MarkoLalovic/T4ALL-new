<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="data"
            type="com.mobility.enp.data.model.api_tags.TagFilterData" />
    </data>

    <RelativeLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tagStatus"
            style="@style/CaptionMedium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/dimens_6dp"
            android:background="@drawable/rounded_status_unmarked_border_"
            android:clickable="true"
            android:paddingStart="@dimen/dimens_16dp"
            android:paddingTop="@dimen/dimens_10dp"
            android:paddingEnd="@dimen/dimens_16dp"
            android:paddingBottom="@dimen/dimens_10dp"
            android:text="@{data.tagText}"
            android:textColor="@color/primary_light_dark"
            tools:text="tagFilter" />


    </RelativeLayout>

</layout>
