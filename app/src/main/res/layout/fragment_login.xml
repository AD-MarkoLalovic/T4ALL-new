<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="user"
            type="com.mobility.enp.data.model.api_room_models.UserLoginResponseRoomTable" />
    </data>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/primary_light_lightest"
        tools:context=".view.fragments.LoginFragment">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/black"
            tools:context=".YourActivity">

            <ProgressBar
                android:id="@+id/progbar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:elevation="@dimen/dimens_10dp"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/topLogoImage"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:layout_alignParentStart="true"
                android:layout_alignParentTop="true"
                android:layout_alignParentEnd="true"
                android:background="@drawable/logo_image"
                android:importantForAccessibility="no" />

            <ImageView
                android:id="@+id/languagePicker"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentTop="true"
                android:layout_alignParentEnd="true"
                android:layout_marginStart="@dimen/dimens_20dp"
                android:layout_marginTop="@dimen/dimens_20dp"
                android:layout_marginEnd="@dimen/dimens_16dp"
                android:layout_marginBottom="@dimen/dimens_20dp"
                android:background="@drawable/select_country_icon"
                android:importantForAccessibility="no" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/topLogoImage"
                android:layout_marginTop="0dp"
                android:background="@drawable/border_login"
                android:backgroundTint="@color/primary_light_lightest"
                android:padding="@dimen/dimens_16dp">

                <TextView
                    android:id="@+id/title"
                    style="@style/H2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimens_6dp"
                    android:text="@string/login_my_profile"
                    android:textColor="@color/primary_light_darkest"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <View
                    android:id="@+id/seperator"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dimens_2dp"
                    android:layout_marginTop="@dimen/dimens_12dp"
                    android:background="@color/primary_light_light"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/title" />

                <TextView
                    android:id="@+id/subtitleLogin"
                    style="@style/ParagraphMedium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimens_16dp"
                    android:text="@string/login_to_existing_account"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/seperator" />

                <TextView
                    android:id="@+id/txLoginHint"
                    style="@style/CaptionRegular"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dimens_16dp"
                    android:layout_marginTop="@dimen/dimens_16dp"
                    android:text="@string/email"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/subtitleLogin" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/emailContainer"
                    style="@style/Paragraph"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimens_8dp"
                    app:boxBackgroundColor="@color/white"
                    app:boxCornerRadiusBottomEnd="@dimen/dimens_84dp"
                    app:boxCornerRadiusBottomStart="@dimen/dimens_84dp"
                    app:boxCornerRadiusTopEnd="@dimen/dimens_84dp"
                    app:boxCornerRadiusTopStart="@dimen/dimens_84dp"
                    app:boxStrokeColor="@color/figmaSplashScreenColor"
                    app:boxStrokeWidth="@dimen/dimens_0dp"
                    app:boxStrokeWidthFocused="@dimen/dimens_1dp"
                    app:endIconMode="clear_text"
                    app:hintEnabled="false"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/txLoginHint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editEmail"
                        style="@style/Paragraph"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:hint="@string/hint_enter_email"
                        android:inputType="textEmailAddress"
                        android:textColor="@color/figmaSplashScreenColor" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/txPasswordHint"
                    style="@style/CaptionRegular"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dimens_16dp"
                    android:layout_marginTop="@dimen/dimens_8dp"
                    android:text="@string/hint_password"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/emailContainer" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/passwordContainer"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimens_8dp"
                    app:boxBackgroundColor="@color/white"
                    app:boxCornerRadiusBottomEnd="@dimen/dimens_84dp"
                    app:boxCornerRadiusBottomStart="@dimen/dimens_84dp"
                    app:boxCornerRadiusTopEnd="@dimen/dimens_84dp"
                    app:boxCornerRadiusTopStart="@dimen/dimens_84dp"
                    app:boxStrokeColor="@color/figmaSplashScreenColor"
                    app:boxStrokeWidth="@dimen/dimens_0dp"
                    app:boxStrokeWidthFocused="@dimen/dimens_1dp"
                    app:endIconMode="custom"
                    app:hintEnabled="false"
                    app:endIconDrawable="@drawable/ic_eye_invisible"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/txPasswordHint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editPassword"
                        style="@style/Paragraph"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:inputType="textPassword"
                        android:hint="@string/enter_your_password"
                        android:textColor="@color/figmaSplashScreenColor" />
                </com.google.android.material.textfield.TextInputLayout>

                <Button
                    android:id="@+id/buttonLogin"
                    style="@style/MyButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimens_8dp"
                    android:text="@string/button_sing_up"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/passwordContainer" />

                <Button
                    android:id="@+id/loginForgetPassword"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:background="@color/transparent"
                    android:fontFamily="@font/noto_sans_bold"
                    android:text="@string/i_forgot_my_password"
                    android:textAllCaps="false"
                    android:textColor="@color/primary_light_darkest"
                    android:textSize="12sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/buttonLogin" />

                <View
                    android:id="@+id/seperatorBottom"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dimens_2dp"
                    android:background="@color/primary_light_light"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/loginForgetPassword" />

                <TextView
                    android:id="@+id/subtitleNewAccount"
                    style="@style/ParagraphMedium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimens_16dp"
                    android:text="@string/create_a_new_account"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/seperatorBottom" />

                <Button
                    android:id="@+id/createAccount"
                    style="@style/MyOutlinedButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimens_16dp"
                    android:text="@string/create_account"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/subtitleNewAccount" />

                <View
                    android:id="@+id/seperatorBottomFinal"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dimens_2dp"
                    android:layout_marginTop="@dimen/dimens_8dp"
                    android:background="@color/primary_light_light"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/createAccount" />

                <View
                    android:id="@+id/center"
                    android:layout_width="@dimen/dimens_1dp"
                    android:layout_height="@dimen/dimens_1dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/seperatorBottomFinal" />

                <View
                    android:id="@+id/centerHorizontal"
                    android:layout_width="@dimen/dimens_2dp"
                    android:layout_height="0dp"
                    android:background="@drawable/linear_gradient_login"
                    app:layout_constraintBottom_toBottomOf="@+id/customerSupport"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/seperatorBottomFinal"
                    app:layout_constraintTop_toTopOf="@+id/customerSupport" />

                <TextView
                    android:id="@+id/customerSupport"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimens_16dp"
                    android:fontFamily="@font/noto_sans_bold"
                    android:text="@string/customer_support"
                    android:textColor="@color/figmaIntroEclipseColorInactive"
                    android:textSize="12sp"
                    app:layout_constraintEnd_toStartOf="@id/center"
                    app:layout_constraintStart_toStartOf="@+id/seperatorBottomFinal"
                    app:layout_constraintTop_toBottomOf="@id/seperatorBottomFinal" />

                <TextView
                    android:id="@+id/privacyTerms"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/noto_sans_bold"
                    android:text="@string/terms_and_conditions"
                    android:textColor="@color/figmaIntroEclipseColorInactive"
                    android:textSize="@dimen/dimens_12sp"
                    android:gravity="center_horizontal"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/centerHorizontal"
                    app:layout_constraintTop_toTopOf="@id/customerSupport" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </RelativeLayout>

    </androidx.core.widget.NestedScrollView>

</layout>