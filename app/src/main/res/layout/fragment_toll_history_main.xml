<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <TextView
        android:id="@+id/titleTollHistory"
        style="@style/H3"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="@dimen/dimens_16dp"
        android:layout_marginEnd="@dimen/dimens_16dp"
        android:text="@string/tool_history"
        app:layout_constraintEnd_toStartOf="@+id/infoIcon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/loopIcon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/dimens_16dp"
        android:background="@drawable/loop"
        android:clickable="true"
        android:contentDescription="@string/loop_icon"
        app:layout_constraintBottom_toBottomOf="@+id/titleTollHistory"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/titleTollHistory" />

    <ImageView
        android:id="@+id/infoIcon"
        android:layout_width="@dimen/dimens_25dp"
        android:layout_height="@dimen/dimens_25dp"
        android:layout_marginEnd="@dimen/dimens_8dp"
        android:background="@drawable/ic_info_rotated"
        android:contentDescription="@string/loop_icon"
        app:layout_constraintBottom_toBottomOf="@+id/titleTollHistory"
        app:layout_constraintEnd_toStartOf="@+id/loopIcon"
        app:layout_constraintTop_toTopOf="@+id/titleTollHistory" />

    <View
        android:id="@+id/line"
        android:layout_width="0dp"
        android:layout_height="@dimen/dimens_1dp"
        android:layout_marginTop="@dimen/dimens_8dp"
        android:background="@color/primary_light_lightest"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/loopIcon" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerAllowedCountries"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimens_16dp"
        android:clipToPadding="false"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/line"
        tools:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        tools:listitem="@layout/item_country_filter"
        tools:orientation="horizontal" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerPassage"
        android:layout_width="@dimen/dimens_0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="@dimen/dimens_16dp"
        android:layout_marginTop="@dimen/dimens_25dp"
        app:layout_constraintBottom_toTopOf="@+id/tollHistoryMainLine"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/recyclerAllowedCountries"/>

    <TextView
        style="@style/Paragraph"
        android:id="@+id/txNoPassage"
        android:layout_width="@dimen/dimens_0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/dimens_16dp"
        android:layout_marginTop="@dimen/dimens_25dp"
        android:text="@string/no_passage_data"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/recyclerAllowedCountries"/>

    <View
        android:id="@+id/tollHistoryMainLine"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimens_1dp"
        android:background="@color/primary_light_light"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ProgressBar
        android:id="@+id/progressTollHistory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


</androidx.constraintlayout.widget.ConstraintLayout>
