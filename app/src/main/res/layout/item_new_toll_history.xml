<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card_group_middle"
    android:orientation="vertical"
    android:paddingHorizontal="@dimen/dimens_8dp"
    android:paddingTop="@dimen/dimens_8dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:elevation="@dimen/dimens_0dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="@dimen/dimens_20dp"
        app:strokeColor="@color/figmaToolHistoryPaidBackground"
        app:strokeWidth="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/containerPassageAmount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/figmaToolHistoryPaidBackground"
                android:padding="@dimen/dimens_16dp">

                <TextView
                    android:id="@+id/tvInvoiceLabel"
                    style="@style/SubtitlesMedium"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/dimens_16dp"
                    android:text="@string/account_number"
                    app:layout_constraintEnd_toStartOf="@+id/tvPassageTotalAmount"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvPassageInvoiceNumber"
                    style="@style/SubtitlesRegular"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:layout_marginEnd="@dimen/dimens_16dp"
                    android:textColor="@color/primary_light_darkest"
                    app:layout_constraintEnd_toStartOf="@+id/tvPassageTotalAmount"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tvInvoiceLabel"
                    tools:text="938087/2026-web" />

                <ImageView
                    android:id="@+id/viewStatusIndicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/status_icon_green"
                    app:layout_constraintBottom_toBottomOf="@+id/tvPassageInvoiceNumber"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/tvInvoiceLabel" />

                <TextView
                    android:id="@+id/tvPassageCurrency"
                    style="@style/ParagraphMedium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/dimens_8dp"
                    android:layout_marginBottom="@dimen/dimens_1dp"
                    android:fontFamily="@font/noto_sans_regular"
                    android:textColor="@color/primary_light_darkest"
                    android:textSize="@dimen/dimens_12sp"
                    app:layout_constraintBottom_toBottomOf="@+id/tvPassageTotalAmount"
                    app:layout_constraintEnd_toStartOf="@+id/viewStatusIndicator"
                    tools:text="RSD" />

                <TextView
                    android:id="@+id/tvPassageTotalAmount"
                    style="@style/ParagraphMedium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/dimens_5dp"
                    android:textColor="@color/primary_light_darkest"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@+id/viewStatusIndicator"
                    app:layout_constraintEnd_toStartOf="@+id/tvPassageCurrency"
                    app:layout_constraintTop_toTopOf="@+id/viewStatusIndicator"
                    tools:text="1.360,00" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/containerPassageRout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:padding="@dimen/dimens_16dp">

                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/passageGuideline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintGuide_percent="0.55" />


                <TextView
                    android:id="@+id/tvRoute"
                    style="@style/CaptionRegular"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/dimens_8dp"
                    android:lineSpacingExtra="@dimen/dimens_0dp"
                    app:layout_constraintEnd_toStartOf="@+id/passageGuideline"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:text="Beograd - Novi Sad" />

                <TextView
                    android:id="@+id/tvCheckIn"
                    style="@style/CaptionRegular"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimens_14dp"
                    android:layout_marginEnd="@dimen/dimens_8dp"
                    android:lineSpacingExtra="@dimen/dimens_0dp"
                    android:textColor="@color/default_logo_profile_color_inner"
                    app:layout_constraintEnd_toStartOf="@+id/passageGuideline"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tvRoute"
                    tools:text="07.04.2026. 11:02" />

                <TextView
                    android:id="@+id/tvCheckOut"
                    style="@style/CaptionRegular"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimens_8dp"
                    android:layout_marginEnd="@dimen/dimens_8dp"
                    android:lineSpacingExtra="@dimen/dimens_0dp"
                    android:textColor="@color/default_logo_profile_color_inner"
                    app:layout_constraintEnd_toStartOf="@+id/passageGuideline"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tvCheckIn"
                    tools:text="07.04.2026. 12:22" />

                <LinearLayout
                    android:id="@+id/btnPassageComplaint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_btn_objection_complaint"
                    android:minHeight="31dp"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/dimens_22dp"
                    android:paddingVertical="@dimen/dimens_6dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="1"
                    app:layout_constraintStart_toEndOf="@id/passageGuideline"
                    tools:visibility="gone">

                    <TextView
                        android:id="@+id/tvComplaintLabel"
                        style="@style/CaptionMedium"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/complaint"
                        android:textStyle="bold" />
                </LinearLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layoutObjection"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginStart="@dimen/dimens_8dp"
                    android:minHeight="31dp"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/passageGuideline"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:visibility="visible">

                    <TextView
                        android:id="@+id/tvComplaintId"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        tools:text="Br. reklamacije #1234" />

                    <LinearLayout
                        android:id="@+id/btnPassageObjection"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dimens_8dp"
                        android:background="@drawable/bg_btn_objection_complaint"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="@dimen/dimens_22dp"
                        android:paddingVertical="@dimen/dimens_6dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvComplaintId"
                        app:layout_constraintVertical_bias="1">

                        <TextView
                            android:id="@+id/tvObjectionLabel"
                            style="@style/CaptionMedium"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/objection"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvObjectionCount"
                            style="@style/CaptionMedium"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/dimens_6dp"
                            android:background="@drawable/figma_objection_background"
                            android:gravity="center"
                            android:minWidth="20dp"
                            android:minHeight="20dp"
                            android:textColor="@color/figmaColorObjection"
                            android:visibility="gone"
                            tools:text="2"
                            tools:visibility="visible" />
                    </LinearLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>


            </androidx.constraintlayout.widget.ConstraintLayout>
        </LinearLayout>


    </com.google.android.material.card.MaterialCardView>

</LinearLayout>