<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/rlContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@color/white">

        <TextView
            android:id="@+id/txtData"
            style="@style/CaptionRegular"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/border_home_unpaid"
            android:paddingHorizontal="@dimen/dimens_10dp"
            android:textColor="@color/primary_light_darkest"
            android:paddingVertical="@dimen/dimens_6dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            tools:text="100 €" />

        <View
            android:id="@+id/spacingView"
            android:layout_width="@dimen/dimens_8dp"
            android:layout_height="0dp"
            app:layout_constraintStart_toEndOf="@+id/txtData"
            app:layout_constraintTop_toTopOf="@+id/txtData"
            app:layout_constraintBottom_toBottomOf="@+id/txtData"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>