<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="countryData"
            type="com.mobility.enp.data.model.registration.CountryModel" />
    </data>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="@dimen/dimens_10dp">

        <ImageView
            android:id="@+id/icon"
            android:layout_width="@dimen/dimens_35dp"
            android:layout_height="@dimen/dimens_35dp"
            android:layout_alignParentStart="true"
            android:layout_alignParentTop="true"
            android:background="@{countryData.countryFlag}"
            tools:background="@drawable/serbia_flag" />

        <TextView
            android:id="@+id/CountryTextField"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignTop="@id/icon"
            android:layout_alignBottom="@id/icon"
            android:layout_marginHorizontal="10dp"
            android:layout_toStartOf="@id/checkbox"
            android:layout_toEndOf="@id/icon"
            android:gravity="center_vertical"
            android:text="@{countryData.countryName}"
            tools:text="Country" />

        <CheckBox
            android:id="@+id/checkbox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignTop="@id/icon"
            android:layout_alignBottom="@id/icon"
            android:layout_alignParentEnd="true"
            android:checked="@{countryData.checked}" />

        <RelativeLayout
            android:id="@+id/tosContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/checkbox"
            android:layout_alignParentStart="true"
            android:layout_alignParentEnd="true"
            android:background="@color/primary_light_light"
            android:paddingVertical="@dimen/dimens_10dp"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:id="@+id/txtDataConfirmation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_toStartOf="@id/checkBoxTos"
                android:text="I confirm the terms and data processing." />

            <CheckBox
                android:id="@+id/checkBoxTos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignTop="@+id/txtDataConfirmation"
                android:layout_alignBottom="@+id/txtDataConfirmation"
                android:layout_alignParentEnd="true"
                android:checked="@{countryData.isTosChecked()}" />
        </RelativeLayout>
    </RelativeLayout>

</layout>
