<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        tools:context=".view.fragments.my_profile.TagPickerRequestFragment">

        <androidx.core.widget.NestedScrollView
            android:layout_width="@dimen/dimens_0dp"
            android:layout_height="@dimen/dimens_0dp"
            android:fillViewport="true"
            app:layout_constraintBottom_toTopOf="@+id/secondLinePickerRequest"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/border_login"
                android:backgroundTint="@color/primary_light_lightest"
                android:paddingHorizontal="@dimen/dimens_16dp">

                <TextView
                    android:id="@+id/txBasicInfo"
                    style="@style/H3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimens_22dp"
                    android:text="@string/refund_request"
                    android:textColor="@color/primary_light_darkest"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <View
                    android:id="@+id/viewTagPicker"
                    android:layout_width="@dimen/dimens_0dp"
                    android:layout_height="@dimen/dimens_1dp"
                    android:layout_marginTop="@dimen/dimens_16dp"
                    android:background="@color/primary_light_light"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/txBasicInfo" />

                <TextView
                    android:id="@+id/textNoTags"
                    style="@style/Paragraph"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimens_16dp"
                    android:text="@string/text_no_refund_tags"
                    android:visibility="gone"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/viewTagPicker" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerViewTagPicker"
                    android:layout_width="@dimen/dimens_0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimens_16dp"
                    android:layout_marginBottom="@dimen/dimens_16dp"
                    android:maxHeight="@dimen/dimens_400dp"
                    android:orientation="vertical"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/viewTagPicker"
                    tools:itemCount="5"
                    tools:listitem="@layout/item_tag_picker_request" />

                <TextView
                    android:id="@+id/txHintAmountTagPicker"
                    style="@style/CaptionRegular"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dimens_16dp"
                    android:layout_marginBottom="@dimen/dimens_8dp"
                    android:text="@string/amount"
                    android:layout_marginTop="@dimen/dimens_22dp"
                    app:layout_constraintTop_toBottomOf="@+id/recyclerViewTagPicker"
                    app:layout_constraintStart_toStartOf="parent" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/txAmountTagPicker"
                    android:layout_width="@dimen/dimens_0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimens_8dp"
                    app:boxBackgroundColor="@color/white"
                    app:boxCornerRadiusBottomEnd="84dp"
                    app:boxCornerRadiusBottomStart="84dp"
                    app:boxCornerRadiusTopEnd="84dp"
                    app:boxCornerRadiusTopStart="84dp"
                    app:boxStrokeColor="@color/figmaSplashScreenColor"
                    app:boxStrokeWidth="@dimen/dimens_0dp"
                    app:boxStrokeWidthFocused="@dimen/dimens_1dp"
                    app:endIconMode="clear_text"
                    app:hintEnabled="false"
                    app:layout_constraintTop_toBottomOf="@+id/txHintAmountTagPicker"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editAmount"
                        style="@style/Paragraph"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="@string/enter_amount"
                        android:imeOptions="actionNext"
                        android:inputType="number"
                        android:paddingVertical="@dimen/dimens_0dp"
                        android:singleLine="true"
                        android:textColor="@color/figmaSplashScreenColor" />
                </com.google.android.material.textfield.TextInputLayout>


                <TextView
                    android:id="@+id/txHintBank"
                    style="@style/CaptionRegular"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dimens_16dp"
                    android:layout_marginTop="@dimen/dimens_8dp"
                    android:text="@string/bank"
                    app:layout_constraintTop_toBottomOf="@+id/txAmountTagPicker"
                    app:layout_constraintStart_toStartOf="parent" />

                <Spinner
                    android:id="@+id/bankSpinner"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimens_8dp"
                    android:background="@drawable/rounded_spinner_background"
                    android:minHeight="@dimen/dimens_48dp"
                    android:popupBackground="@color/white"
                    android:spinnerMode="dropdown"
                    app:layout_constraintTop_toBottomOf="@+id/txHintBank"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />


                <TextView
                    android:id="@+id/txHintBankAccount"
                    style="@style/CaptionRegular"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dimens_16dp"
                    android:layout_marginTop="@dimen/dimens_8dp"
                    android:text="@string/bank_account"
                    app:layout_constraintTop_toBottomOf="@+id/bankSpinner"
                    app:layout_constraintStart_toStartOf="parent" />

                <Spinner
                    android:id="@+id/uniqueNumbersSpinner"
                    android:layout_width="@dimen/dimens_80dp"
                    android:layout_height="48dp"
                    android:layout_marginTop="@dimen/dimens_8dp"
                    android:background="@drawable/rounded_left_spinner_background"
                    android:backgroundTint="@color/soft_gray"
                    android:popupBackground="@color/white"
                    android:spinnerMode="dropdown"
                    app:layout_constraintTop_toBottomOf="@+id/txHintBankAccount"
                    app:layout_constraintStart_toStartOf="parent" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/txCenterAccountNumber"
                    android:layout_width="@dimen/dimens_0dp"
                    android:layout_height="48dp"
                    app:boxBackgroundColor="@color/soft_gray"
                    app:boxCornerRadiusBottomEnd="@dimen/dimens_0dp"
                    app:boxCornerRadiusBottomStart="@dimen/dimens_0dp"
                    app:boxCornerRadiusTopEnd="@dimen/dimens_0dp"
                    app:boxCornerRadiusTopStart="@dimen/dimens_0dp"
                    app:boxStrokeColor="@color/figmaSplashScreenColor"
                    app:boxStrokeWidth="@dimen/dimens_0dp"
                    app:boxStrokeWidthFocused="@dimen/dimens_1dp"
                    app:hintEnabled="false"
                    app:layout_constraintBottom_toBottomOf="@+id/uniqueNumbersSpinner"
                    app:layout_constraintEnd_toStartOf="@+id/etSecondTagPicker"
                    app:layout_constraintStart_toEndOf="@+id/uniqueNumbersSpinner">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etCenterAccountNumber"
                        style="@style/Paragraph"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:clickable="false"
                        android:cursorVisible="false"
                        android:focusable="false"
                        android:focusableInTouchMode="false"
                        android:gravity="center"
                        android:imeOptions="actionNext"
                        android:importantForAccessibility="no"
                        android:inputType="number"
                        android:maxLength="13"
                        android:padding="@dimen/dimens_0dp"
                        android:textColor="@color/figmaSplashScreenColor"
                        tools:text="1234567891" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/etSecondTagPicker"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:background="@drawable/spinner_bank_account_selector"
                    android:backgroundTint="@color/soft_gray"
                    app:boxStrokeWidth="@dimen/dimens_0dp"
                    app:boxStrokeWidthFocused="@dimen/dimens_0dp"
                    app:hintEnabled="false"
                    app:layout_constraintBottom_toBottomOf="@+id/uniqueNumbersSpinner"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/uniqueNumbersSpinner">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etRightAccountNumber"
                        style="@style/Paragraph"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:clickable="false"
                        android:cursorVisible="false"
                        android:focusable="false"
                        android:focusableInTouchMode="false"
                        android:gravity="center"
                        android:imeOptions="actionNext"
                        android:importantForAccessibility="no"
                        android:inputType="number"
                        android:maxLength="2"
                        android:padding="@dimen/dimens_0dp"
                        android:textColor="@color/figmaSplashScreenColor"
                        tools:text="12" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/refundRequestNote"
                    style="@style/Paragraph"
                    android:layout_width="wrap_content"
                    android:layout_height="0dp"
                    android:gravity="bottom"
                    android:layout_marginTop="@dimen/dimens_22dp"
                    android:layout_marginBottom="@dimen/dimens_16dp"
                    android:text="@string/refund_request_note"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/uniqueNumbersSpinner"
                    app:layout_constraintStart_toStartOf="parent" />


            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.core.widget.NestedScrollView>

        <ProgressBar
            android:id="@+id/refundLoadingTagPicker"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/secondLinePickerRequest"
            android:layout_width="@dimen/dimens_0dp"
            android:layout_height="@dimen/dimens_1dp"
            android:layout_marginBottom="@dimen/dimens_8dp"
            android:background="@color/primary_light_light"
            app:layout_constraintBottom_toTopOf="@+id/buttonSendRequest"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <Button
            android:id="@+id/buttonSendRequest"
            style="@style/MyButtonStyle"
            android:layout_width="@dimen/dimens_0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/dimens_16dp"
            android:layout_marginBottom="@dimen/dimens_8dp"
            android:text="@string/send"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />


    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>