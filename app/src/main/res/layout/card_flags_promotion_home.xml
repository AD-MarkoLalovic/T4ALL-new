<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="data"
            type="com.mobility.enp.data.model.home.cards.entity.HomeCardsEntity" />
    </data>

    <RelativeLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/dimens_15dp">

        <androidx.cardview.widget.CardView
            android:layout_width="@dimen/dimens_300dp"
            android:layout_height="200dp"
            android:elevation="10dp"
            app:cardCornerRadius="@dimen/dimens_25dp">

            <ImageView
                android:id="@+id/backgroundImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@null"
                android:scaleType="centerCrop"
                tools:src="@drawable/flag_home_macedonian" />

            <TextView
                android:id="@+id/cardTitle"
                style="@style/CaptionMedium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/dimens_16dp"
                android:layout_marginTop="@dimen/dimens_10dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:scrollHorizontally="true"
                android:text="@{data.title}"
                android:textColor="@color/white"
                tools:text="North Macedonian passage" />

            <TextView
                android:id="@+id/cardSubtitle"
                style="@style/CaptionRegular"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/dimens_16dp"
                android:layout_marginTop="@dimen/dimens_40dp"
                android:ellipsize="end"
                android:lineSpacingExtra="@dimen/dimens_4sp"
                android:maxLines="5"
                android:scrollHorizontally="true"
                android:text="@{data.description}"
                android:textColor="@color/white"
                tools:text="@string/lorem" />


            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnObjection"
                    style="@style/MyButtonStyleSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/dimens_45dp"
                    android:layout_gravity="bottom"
                    android:layout_marginStart="@dimen/dimens_20dp"
                    android:layout_marginBottom="@dimen/dimens_10dp"
                    android:text="@string/add_card_home"
                    android:textSize="@dimen/dimens_10sp" />

                <ImageView
                    android:id="@+id/btnSocialNetworks"
                    android:layout_width="@dimen/dimens_50dp"
                    android:layout_height="45dp"
                    android:layout_marginBottom="@dimen/dimens_10dp"
                    android:layout_toEndOf="@id/btnObjection"
                    android:background="@drawable/arrow_background_social_networks"
                    android:contentDescription="@string/facebook"
                    android:textSize="@dimen/dimens_10sp"
                    android:visibility="gone"
                    tools:visibility="visible" />
            </RelativeLayout>

            <ImageView
                android:id="@+id/closeButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_margin="@dimen/dimens_10dp"
                android:contentDescription="@string/button_close"
                android:elevation="@dimen/dimens_10dp"
                android:src="@drawable/close_button" />

        </androidx.cardview.widget.CardView>

    </RelativeLayout>

</layout>