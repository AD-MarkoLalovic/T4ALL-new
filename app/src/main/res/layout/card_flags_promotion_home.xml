<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="data"
            type="com.mobility.enp.data.model.home.cards.entity.HomeCardsEntity" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/dimens_16dp">

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="180dp"
            android:elevation="10dp"
            app:cardCornerRadius="@dimen/dimens_26dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/backgroundImage"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:contentDescription="@null"
                    android:scaleType="centerCrop"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:src="@drawable/flag_home_macedonian" />

                <TextView
                    android:id="@+id/cardTitle"
                    style="@style/ParagraphMedium"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dimens_16dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginEnd="@dimen/dimens_16dp"
                    android:lineSpacingExtra="1dp"
                    android:paddingTop="0dp"
                    android:paddingBottom="0dp"
                    android:text="@{data.title}"
                    android:textColor="@color/white"
                    app:layout_constraintEnd_toStartOf="@+id/closeButton"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:text="North Macedonian passage" />

                <TextView
                    android:id="@+id/cardSubtitle"
                    style="@style/CaptionRegular"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dimens_16dp"
                    android:layout_marginTop="@dimen/dimens_12dp"
                    android:layout_marginEnd="@dimen/dimens_16dp"
                    android:lineSpacingExtra="0dp"
                    android:text="@{data.description}"
                    android:textColor="@color/white"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.0"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/cardTitle"
                    app:layout_constraintVertical_bias="0.0"
                    tools:text="@string/tag_device_payment_method_north_macedonia" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnObjection"
                    style="@style/MyButtonStyleSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:paddingVertical="@dimen/dimens_0dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginBottom="16dp"
                    android:text="@string/add_card_home"
                    android:gravity="center"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <ImageView
                    android:id="@+id/btnSocialNetworks"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/arrow_background_social_networks"
                    android:contentDescription="@string/facebook"
                    android:textSize="@dimen/dimens_10sp"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="@+id/btnObjection"
                    app:layout_constraintTop_toTopOf="@+id/btnObjection"
                    app:layout_constraintStart_toEndOf="@id/btnObjection"
                    tools:visibility="visible" />

                <ImageView
                    android:id="@+id/closeButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/dimens_16dp"
                    android:layout_marginTop="@dimen/dimens_12dp"
                    android:contentDescription="@string/button_close"
                    android:elevation="@dimen/dimens_10dp"
                    android:src="@drawable/close_button"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>
