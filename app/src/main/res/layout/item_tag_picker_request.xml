<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="tag"
            type="com.mobility.enp.view.ui_models.refund_request.TagsRefundRequestUIModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/refundRequestTable"
            style="@style/SubtitlesRegular"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@{tag.registrationPlate}"
            app:layout_constraintBottom_toBottomOf="@+id/refundRequestRadioButton"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/refundRequestRadioButton"
            tools:text="BG2285OI" />

        <TextView
            android:id="@+id/refundRequestSerialNumber"
            style="@style/SubtitlesRegular"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dimens_16dp"
            android:text="@{tag.serialNumber}"
            app:layout_constraintBottom_toBottomOf="@+id/refundRequestRadioButton"
            app:layout_constraintStart_toEndOf="@+id/refundRequestTable"
            app:layout_constraintTop_toTopOf="@id/refundRequestRadioButton"
            tools:text="CE040219221130628" />

        <RadioButton
            android:id="@+id/refundRequestRadioButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/dimens_1dp"
            android:background="@color/primary_light_light"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/refundRequestRadioButton" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>